---
layout: none
---
[
  {% for post in site.posts %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "category": {{ post.category | default: "Article" | jsonify }},
      "date": "{{ post.date | date: '%d/%m/%Y' }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
